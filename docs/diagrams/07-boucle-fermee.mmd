flowchart LR
    subgraph "Mode AUTO : la boucle est fermée"
        direction TB
        M[Mesures] --> FUZ[Système expert<br/>24 règles]
        FUZ --> DEC[(Decision)]
        DEC --> AL[Alertes / UI]
        DEC -->|"actuator : si AUTOMATIC"| RS[(RelayState)]
        U[Utilisateur<br/>mode MANUAL] -.->|sinon| RS
        RS --> ESP[ESP32 → relais → charges]
    end
    style DEC fill:#eef
    style RS fill:#efe