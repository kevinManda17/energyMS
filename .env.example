# ---- Global EMS environment (docker-compose.prod.yml) ----

# Database
POSTGRES_DB=ems_db
POSTGRES_USER=ems_user
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://ems_user:change-me@db:5432/ems_db

# Django
DJANGO_SECRET_KEY=change-me-in-production
# Hotes seulement (pas de scheme http://, pas de port, pas de chemin /api).
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,172.20.10.14
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,192.168.84.117
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,192.168.84.117
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# SMS / phone verification
SMS_PROVIDER=console
SMS_API_KEY=
SMS_SENDER=EMS

# Frontend (build arg)
# VITE_API_BASE_URL=http://172.20.10.14:8000/api
# VITE_API_BASE_URL=http://192.168.84.117:8000/api
VITE_API_BASE_URL=http://192.168.84.117:8000/api

# Email verification / password reset
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@ems.local
# FRONTEND_URL=http://172.20.10.14:5173
# FRONTEND_URL=http://192.168.84.117:5173
FRONTEND_URL=http://192.168.84.117:5173


PASSWORD_RESET_TOKEN_MINUTES=30
EMAIL_VERIFICATION_TOKEN_MINUTES=60

