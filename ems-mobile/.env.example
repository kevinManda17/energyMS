# Copier vers .env puis adapter l'IP au reseau courant.
# Expo n'expose au bundle que les variables prefixees EXPO_PUBLIC_.
# Apres modification : redemarrer avec `npx expo start --clear`.

# EXPO_PUBLIC_API_BASE_URL=http://172.20.10.14:8000/api
# EXPO_PUBLIC_API_BASE_URL=http://192.168.203.117:8000/api
EXPO_PUBLIC_API_BASE_URL=http://192.168.188.117:8000/api

# EXPO_PUBLIC_EDGE_API_URL=http://172.20.10.14:8000/api
# EXPO_PUBLIC_EDGE_API_URL=http://192.168.203.117:8000/api
EXPO_PUBLIC_EDGE_API_URL=http://192.168.188.117:8000/api

EXPO_PUBLIC_APP_NAME=EMS Mobile
