# Copier vers .env puis adapter l'IP au réseau courant.
# Expo n'expose au bundle que les variables préfixées EXPO_PUBLIC_.
# Après modification : redémarrer avec `npx expo start --clear`.
#
# ⚠ Ne JAMAIS mettre localhost ici : sur un téléphone, localhost désigne le
# téléphone, pas le PC qui héberge l'API. Il faut l'adresse LAN du PC.
# Pour la retrouver : python scripts/configure_lan.py
EXPO_PUBLIC_API_BASE_URL=http://192.168.0.117:8000/api
EXPO_PUBLIC_EDGE_API_URL=http://192.168.0.117:8000/api

EXPO_PUBLIC_APP_NAME=EMS Mobile
