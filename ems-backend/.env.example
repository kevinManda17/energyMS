DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

DATABASE_URL=postgresql://ems_user:ems_password@db:5432/ems_db

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60

MQTT_BROKER=mqtt
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

SMS_PROVIDER=console
SMS_API_KEY=
SMS_SENDER=EMS

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@ems.local
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_MINUTES=30
EMAIL_VERIFICATION_TOKEN_MINUTES=60

# === Modèles ML (AI2) ===
# Chemin absolu vers le dossier AI2 contenant les modèles entraînés
AI2_PATH=/home/kevin/Documents/KEVIN/memoire/projet/AI2

# === API Météo Open-Meteo ===
# Coordonnées GPS de repli (latitude, longitude) pour les maisons sans
# coordonnées propres — chaque maison peut définir les siennes (modifiables
# dans l'interface, page Micro-réseaux).
# Kinshasa: -4.3276, 15.3136 | Goma: -1.6796, 29.2225
# Lubumbashi: -11.6638, 27.4794
WEATHER_LATITUDE=-4.3276
WEATHER_LONGITUDE=15.3136

# Collecte météo automatique en tâche de fond (en plus du bouton manuel des
# interfaces web/mobile et de la commande `manage.py fetch_weather`).
WEATHER_AUTO_COLLECT=1
WEATHER_COLLECT_INTERVAL_MINUTES=15

