# Copier vers .env puis adapter l'IP au réseau courant.
# Vite ne lit QUE .env / .env.local — jamais .env.example.
# Pour retrouver l'adresse LAN du PC : python scripts/configure_lan.py
#
# Si VITE_API_BASE_URL est absent, le frontend construit l'URL depuis l'hôte de
# la page (window.location.hostname:8000/api) — voir src/api/baseUrl.js. Ce
# repli suppose que backend et frontend tournent sur la même machine.
VITE_API_BASE_URL=http://192.168.84.117:8000/api
VITE_WS_URL=ws://192.168.84.117:8000/ws

VITE_APP_NAME=EMS Dashboard
